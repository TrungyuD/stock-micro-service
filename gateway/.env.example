# =============================================================================
# gateway — Environment Variables Template
# Copy to .env. NEVER commit .env to git.
# =============================================================================

# Server
GATEWAY_PORT=5301
NODE_ENV=development

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5300

# gRPC service addresses
INFORMER_GRPC_URL=localhost:5302
ANALYTICS_GRPC_URL=localhost:5303

# Database (direct connection, used for health checks)
DB_HOST=localhost
DB_PORT=5311
DB_USER=stock_user
DB_PASSWORD=stock_password
DB_NAME=stock_db

# JWT Authentication
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7
