# =============================================================================
# gateway — Environment Variables Template
# Copy to .env. NEVER commit .env to git.
# =============================================================================

# Server
GATEWAY_PORT=3001
NODE_ENV=development

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# gRPC service addresses
INFORMER_GRPC_URL=localhost:50051
ANALYTICS_GRPC_URL=localhost:50052

# Database (direct connection, used for health checks)
DB_HOST=localhost
DB_PORT=5432
DB_USER=stock_user
DB_PASSWORD=stock_password
DB_NAME=stock_db
