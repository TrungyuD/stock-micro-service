# =============================================================================
# stock-micro-service — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- PostgreSQL / TimescaleDB ---
DB_HOST=localhost
DB_PORT=5433
DB_USER=stock_user
DB_PASSWORD=stock_password
DB_NAME=stock_db

# --- pgAdmin ---
PGADMIN_EMAIL=admin@stock.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- gRPC Service Ports ---
INFORMER_GRPC_HOST=localhost
INFORMER_GRPC_PORT=50051
ANALYTICS_GRPC_HOST=localhost
ANALYTICS_GRPC_PORT=50052

# --- NestJS Gateway ---
GATEWAY_PORT=5301
NODE_ENV=development

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# --- JWT (for future auth) ---
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
