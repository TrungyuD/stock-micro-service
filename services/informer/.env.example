# =============================================================================
# informer service — Environment Variables Template
# Copy to .env. NEVER commit .env to git.
# =============================================================================

# ── gRPC server ───────────────────────────────────────────────────────────────
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
GRPC_MAX_WORKERS=10

# ── PostgreSQL / TimescaleDB ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=stock_user
DB_PASSWORD=stock_password
DB_NAME=stock_db
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── yfinance ──────────────────────────────────────────────────────────────────
YFINANCE_TIMEOUT=30
YFINANCE_MAX_RETRIES=3

# ── Alpha Vantage (optional fallback — free tier: 5 req/min) ──────────────────
# Leave empty to disable Alpha Vantage fallback
ALPHA_VANTAGE_KEY=

# ── Scheduler ─────────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=true
# Daily OHLCV collection time (US/Eastern timezone)
COLLECTION_HOUR=16
COLLECTION_MINUTE=30

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
