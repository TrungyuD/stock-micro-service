# =============================================================================
# analytics service — Environment Variables Template
# Copy to .env. NEVER commit .env to git.
# =============================================================================

# gRPC server
GRPC_HOST=0.0.0.0
GRPC_PORT=5303
GRPC_MAX_WORKERS=10

# PostgreSQL
DB_HOST=localhost
DB_PORT=5311
DB_USER=stock_user
DB_PASSWORD=stock_password
DB_NAME=stock_db

DB_POOL_MIN=2
DB_POOL_MAX=10

# Scheduler — recalculate after US market close
ENABLE_SCHEDULER=true
CALC_HOUR=17
CALC_MINUTE=0

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
